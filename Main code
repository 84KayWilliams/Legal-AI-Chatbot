<h1>CREAC Legal Writing AI</h1>

<textarea id="input">
TASK TYPE: Predictive Memo

JURISDICTION:
- Federal: Yes
- State(s): Georgia

AREA OF LAW:
Negligence

FACTS:
A driver ran a red light and struck a pedestrian in a crosswalk.

LEGAL QUESTION:
Is the driver liable for negligence?

OUTPUT LEVEL:
Law Student
</textarea>

<button onclick="sendRequest()">Generate Memo</button>

<div id="response"></div>

<script>
async function sendRequest() {
    const input = document.getElementById("input").value;
    const responseDiv = document.getElementById("response");

    responseDiv.innerHTML = "<p class='loading'>Generating...</p>";

    try {
        const res = await fetch("/generate", {
            method: "POST",
            headers: {"Content-Type": "application/json"},
            body: JSON.stringify({ input })
        });

        const data = await res.json();
        responseDiv.innerText = data.response || data.error;
    } catch (error) {
        responseDiv.innerText = "Error connecting to server.";
    }
}
</script>

